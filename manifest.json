{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.2.2",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": ["storage", "activeTab", "clipboardWrite", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": { "default": "Alt+F" },
      "description": "__MSG_cmdTogglePanel__"
    },
    "new-session-tab": {
      "suggested_key": { "default": "Alt+N" },
      "description": "__MSG_cmdNewSession__"
    },
    "add-to-total": {
      "suggested_key": { "default": "Alt+A" },
      "description": "__MSG_cmdAdd__"
    },
    "subtract-from-total": {
      "suggested_key": { "default": "Alt+S" },
      "description": "__MSG_cmdSubtract__"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://chrome.google.com/webstore/*",
        "https://chromewebstore.google.com/*"
      ],
      "js": [
        "lib/number-parse.js",
        "lib/parser.js",
        "lib/storage-model.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
